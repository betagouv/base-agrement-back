// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
  // generatedFileExtension = "js"
}

generator erd {
  provider = "prisma-erd-generator"
  disabled = env("CI")
}

datasource db {
  provider = "postgresql"
}

model personne {
  id                           String                         @id @default(cuid())
  civilite                     String
  nom_naissance                String
  nom_usage                    String?
  prenom_1                     String
  prenom_2                     String?
  prenom_3                     String?
  date_naissance               DateTime                       @db.Date
  lieu_naissance_pays          String
  lieu_naissance_commune       String?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt

  agrement_assistant_maternel  agrement_assistant_maternel?
  agrement_assistant_familial  agrement_assistant_familial?
}

model agrement_assistant_maternel {
  id                                          String              @id @default(cuid())
  personne_id                                 String              @unique
  personne                                    personne            @relation(fields: [personne_id], references: [id], onDelete: Cascade)

  adresses_accueil                            adresse_accueil[]

  identifiant_departement            String
  date_premiere_delivrance           DateTime            @db.Date
  date_renouvellement                DateTime?           @db.Date
  date_suspension_temporaire         DateTime?           @db.Date
  date_fin_suspension_temporaire     DateTime?           @db.Date
  date_cessation_temporaire          DateTime?           @db.Date
  date_fin_cessation_temporaire      DateTime?           @db.Date
  date_retrait                       DateTime?           @db.Date
  date_fin_definitive                DateTime?           @db.Date

  createdAt                                   DateTime            @default(now())
  updatedAt                                   DateTime            @updatedAt
}

model agrement_assistant_familial {
  id                                          String              @id @default(cuid())
  personne_id                                 String              @unique
  personne                                    personne            @relation(fields: [personne_id], references: [id], onDelete: Cascade)

  adresses_accueil                            adresse_accueil[]

  identifiant_departement            String
  date_premiere_delivrance           DateTime            @db.Date
  date_renouvellement                DateTime?           @db.Date
  date_suspension_temporaire         DateTime?           @db.Date
  date_fin_suspension_temporaire     DateTime?           @db.Date
  date_cessation_temporaire          DateTime?           @db.Date
  date_fin_cessation_temporaire      DateTime?           @db.Date
  date_retrait                       DateTime?           @db.Date
  date_fin_definitive                DateTime?           @db.Date
  diplome_date_obtention                      DateTime            @db.Date

  createdAt                                   DateTime            @default(now())
  updatedAt                                   DateTime            @updatedAt
}

model adresse_accueil {
  id                                          String                        @id @default(cuid())

  numero_voie                                 String                        @db.VarChar(10)
  complement_voie                             String?
  code_postal                                 String                        @db.Char(5)
  code_insee_commune                          String

  agrement_assistant_maternel_id              String?
  agrement_assistant_maternel                 agrement_assistant_maternel?  @relation(fields: [agrement_assistant_maternel_id], references: [id], onDelete: Cascade)

  agrement_assistant_familial_id              String?
  agrement_assistant_familial                 agrement_assistant_familial?  @relation(fields: [agrement_assistant_familial_id], references: [id], onDelete: Cascade)

  createdAt                                   DateTime                      @default(now())
  updatedAt                                   DateTime                      @updatedAt
}





